{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentworkos.dev/schemas/agentpkg.schema.json",
  "title": "AgentWorkOS Package Manifest",
  "type": "object",
  "required": ["package", "source", "install"],
  "properties": {
    "package": {
      "type": "object",
      "required": ["id", "name", "type", "version"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "enum": ["skill", "agent", "rule", "terms", "prompt", "sop", "hook", "mcp", "repo"]
        },
        "version": { "type": "string" },
        "description": { "type": "string" },
        "license": { "type": "string" }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "properties": {
        "repo": { "type": "string" },
        "path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "install": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": { "type": "string" }
      },
      "additionalProperties": true
    },
    "targets": {
      "type": "array",
      "items": { "$ref": "#/$defs/targetRef" }
    },
    "verify": {
      "type": "object",
      "properties": {
        "entrypoint": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "targetRef": {
      "type": "object",
      "required": ["runtime", "install_to"],
      "properties": {
        "runtime": { "enum": ["codex", "claude", "claude-code"] },
        "install_to": { "type": "string", "minLength": 1 },
        "adapter": { "type": "string" },
        "lossiness": { "type": "string" },
        "verify": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
